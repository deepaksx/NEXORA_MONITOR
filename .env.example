# Nexora Monitor — environment configuration
# Copy to .env for local dev, or set these in Render's dashboard.

# PostgreSQL host that has the agent_brain, nxsys, and npm_projects databases.
# Local (on the EC2 box itself) = localhost
# Remote (Render) = public IP or hostname, requires DB to accept external connections + TLS
DB_HOST=localhost
DB_PORT=5432
DB_USER=npm
DB_PASSWORD=changeme

# How often the browser re-polls /api/status (seconds)
REFRESH_SECONDS=15

# Freshness thresholds (minutes). Stages older than these go yellow/red.
FRESHNESS_WARN_MIN=120
FRESHNESS_CRIT_MIN=360

# Optional basic auth — if set, dashboard requires these credentials.
# Leave blank to disable auth (NOT recommended for public deployment).
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=
